<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.studentprofilemanager.controller.LoginController"
            styleClass="app-background"
            prefWidth="900" prefHeight="600"
            stylesheets="@../css/style.css">

    <center>

        <StackPane BorderPane.alignment="CENTER">

            <VBox fx:id="loginCard"
                  styleClass="login-card"
                  alignment="TOP_CENTER"
                  spacing="16"
                  maxWidth="380"
                  maxHeight="-Infinity">

                <!-- Logo / brand -->
                <Label text="SPM" styleClass="logo-badge"/>

                <Label text="Student Profile Manager" styleClass="title"/>
                <Label text="Sign in to continue to your account" styleClass="subtitle"/>

                <!-- Username -->
                <VBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="Username" styleClass="field-label"/>
                    <TextField fx:id="usernameField"
                               promptText="Enter your username"
                               maxWidth="Infinity"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="Password" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   maxWidth="Infinity"/>
                </VBox>

                <!-- Actions -->
                <Button text="Login"
                        fx:id="loginButton"
                        onAction="#login"
                        styleClass="btn-primary"
                        maxWidth="Infinity">
                    <VBox.margin>
                        <Insets top="6"/>
                    </VBox.margin>
                </Button>

                <Button text="Exit"
                        onAction="#exit"
                        styleClass="btn-secondary"
                        maxWidth="Infinity"/>

            </VBox>

        </StackPane>

    </center>

</BorderPane>
