<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.studentprofilemanager.controller.SearchStudentController"
            prefWidth="1000" prefHeight="640"
            stylesheets="@../css/style.css">

    <!-- ============ SIDEBAR ============ -->
    <left>

        <VBox styleClass="sidebar" spacing="8">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="SPM" styleClass="avatar"/>
                <VBox spacing="1">
                    <Label text="Student Profile" styleClass="app-name"/>
                    <Label text="Manager" styleClass="app-tag"/>
                </VBox>
            </HBox>

            <Region prefHeight="24"/>

            <Button text="Dashboard" onAction="#goDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Students" onAction="#goStudents" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Add Student" onAction="#goAddStudent" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="Search" onAction="#goSearch" styleClass="nav-button-active" maxWidth="Infinity"/>
            <Button text="Reports" styleClass="nav-button" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Logout"
                    onAction="#logout"
                    styleClass="btn-danger"
                    maxWidth="Infinity"/>

        </VBox>

    </left>

    <!-- ============ HEADER ============ -->
    <top>

        <HBox styleClass="header" spacing="20" alignment="CENTER_LEFT">

            <VBox spacing="2">
                <Label text="Search Students" styleClass="title"/>
                <Label text="Find student records quickly" styleClass="subtitle"/>
            </VBox>

            <Pane HBox.hgrow="ALWAYS"/>

            <HBox styleClass="admin-chip" spacing="10" alignment="CENTER_LEFT">
                <Label text="A" styleClass="avatar"/>
                <VBox spacing="0">
                    <Label text="Administrator" styleClass="field-label"/>
                    <Label text="admin@example.edu" styleClass="muted"/>
                </VBox>
            </HBox>

        </HBox>

    </top>

    <!-- ============ CONTENT ============ -->
    <center>

        <VBox styleClass="content-area" spacing="20">

            <!-- Search card -->
            <VBox styleClass="card" spacing="16">

                <Label text="Search" styleClass="section-title"/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               promptText="Enter student ID, name, course or email…"
                               HBox.hgrow="ALWAYS"
                               maxWidth="Infinity"/>
                    <Button text="Search" onAction="#search" styleClass="btn-primary"/>
                    <Button text="Reset" onAction="#reset" styleClass="btn-secondary"/>
                </HBox>

            </VBox>

            <!-- Results card -->
            <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Results" styleClass="section-title"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusLabel" text="Enter a keyword to begin" styleClass="status-label"/>
                </HBox>

                <TableView fx:id="resultTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="Student ID" prefWidth="110"/>
                        <TableColumn fx:id="colName" text="Name" prefWidth="180"/>
                        <TableColumn fx:id="colCourse" text="Course" prefWidth="90"/>
                        <TableColumn fx:id="colYear" text="Year" prefWidth="60"/>
                        <TableColumn fx:id="colSection" text="Section" prefWidth="80"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                        <TableColumn fx:id="colContact" text="Contact" prefWidth="130"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

            </VBox>

        </VBox>

    </center>

</BorderPane>
