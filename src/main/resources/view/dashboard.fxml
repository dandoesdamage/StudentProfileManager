<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.studentprofilemanager.controller.DashboardController"
            stylesheets="@../css/style.css">

    <top>

        <HBox spacing="20"
              alignment="CENTER_LEFT">

            <padding>

                <Insets top="15"
                        right="20"
                        bottom="15"
                        left="20"/>

            </padding>

            <Label text="Dashboard"
                   styleClass="title"/>

            <Pane HBox.hgrow="ALWAYS"/>

            <Button text="Logout"
                    onAction="#logout"/>

        </HBox>

    </top>

    <center>

        <VBox alignment="CENTER"
              spacing="20">

            <Label text="Welcome Administrator"/>

            <Label text="Student Profile Manager"/>

        </VBox>

    </center>

</BorderPane>